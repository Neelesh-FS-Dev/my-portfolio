# GitHub API tokens (server-side only — never expose to the browser)
GITHUB_TOKEN_PERSONAL=your_personal_github_token
GITHUB_TOKEN_COMPANY=your_company_github_token
GITHUB_USERNAME_PERSONAL=your_personal_github_username
GITHUB_USERNAME_COMPANY=your_company_github_username

# Resend email API key
RESEND_API_KEY=your_resend_api_key

# Your deployed portfolio URL (e.g. https://your-portfolio.vercel.app)
# Used to restrict API CORS to your domain only
ALLOWED_ORIGIN=https://your-portfolio.vercel.app
